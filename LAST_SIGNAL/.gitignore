# Godot 4 editor & import cache
.godot/
.import/
*.import.tmp

# Exported builds
/export/
/build/
/builds/
*.exe
*.pck
*.zip
*.apk
*.aab

# Generated audio — reproduce with: python3 tools/generate_audio.py
audio/music/*.wav
audio/sfx/*.wav

# Image assets — materialize with: python3 tools/decode_assets.py
assets/sprites/player/*.png
assets/sprites/enemies/*.png
assets/branding/*.png
marketing/screenshots/*.png

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*~
